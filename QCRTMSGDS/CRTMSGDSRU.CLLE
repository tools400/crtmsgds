     /* =================================================================== */
     /*   >>PRE-COMPILER<<                                                  */
     /*     >>CRTCMD<<    CRTBNDCL  PGM(QTEMP/&OB) +                        */
     /*                             SRCFILE(&SL/&SF) SRCMBR(&SM);           */
     /*     >>IMPORTANT<<                                                   */
     /*       >>PARM<<    OPTION(*EVENTF);                                  */
     /*     >>END-IMPORTANT<<                                               */
     /*     >>EXECUTE<<                                                     */
     /*     >>CMD<<       CALL   PGM(QTEMP/&OB) PARM('&LI' '&OB');          */
     /*     >>CMD<<       DLTPGM PGM(QTEMP/&OB);                            */
     /*   >>END-PRE-COMPILER<<                                              */
     /* =================================================================== */
             PGM        PARM(&TOLIB &MSGF)

             DCL        VAR(&TOLIB    ) TYPE(*CHAR) LEN(10)
             DCL        VAR(&MSGF     ) TYPE(*CHAR) LEN(10)

             DLTMSGF    MSGF(&TOLIB/&MSGF)
             MONMSG     MSGID(CPF2105)

             CRTMSGF    MSGF(&TOLIB/&MSGF) TEXT('CRTMSGDS - Message file for unit tests.')

             ADDMSGD    MSGID(USR0001) MSGF(&TOLIB/&MSGF) +
                        MSG('A test message with replacement variables.') +
                        FMT( +
                          (*QTDCHAR 10  ) +
                          (*CHAR    20  ) +
                          (*HEX     12  ) +
                          (*DEC     15 5) +
                          (*BIN      8  ) +
                          (*BIN      4  ) +
                          (*BIN      2  ) +
                          (*UBIN     8  ) +
                          (*UBIN     4  ) +
                          (*UBIN     2  ) +
                        )

             ADDMSGD    MSGID(USR0002) MSGF(&TOLIB/&MSGF) +
                        MSG('A test message without replacement variables.')

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_FREE  ) REPLACE(*YES) TYPE(*FREE)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_ILERPG) REPLACE(*YES) TYPE(*ILERPG)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_RPG   ) REPLACE(*YES) TYPE(*RPG)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_C     ) REPLACE(*YES) TYPE(*C)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_CL    ) REPLACE(*YES) TYPE(*CL)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_CLP   ) REPLACE(*YES) TYPE(*CLP)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_CLLE  ) REPLACE(*YES) TYPE(*CLLE)

             CRTMSGDS RANGE(*ALL) MSGF(&TOLIB/&MSGF) FILE(QCRTMSGDS) +
                      MBR(X_SCRIPT) REPLACE(*YES) TYPE(*SCRIPT)


             ENDPGM
